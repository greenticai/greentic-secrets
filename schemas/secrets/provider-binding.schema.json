{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.greentic.ai/secrets/provider-binding.schema.json",
  "title": "Greentic secrets provider binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider_id", "pack", "config"],
  "properties": {
    "schema_version": {
      "const": "greentic.secrets.binding.v1"
    },
    "provider_id": {
      "type": "string",
      "enum": [
        "greentic.secrets.aws-sm",
        "greentic.secrets.gcp-sm",
        "greentic.secrets.azure-kv",
        "greentic.secrets.k8s",
        "greentic.secrets.vault-kv"
      ]
    },
    "pack": {
      "type": "string",
      "minLength": 1
    },
    "config": {
      "type": "object",
      "required": ["namespace_prefix"],
      "not": {
        "required": ["prefix"]
      },
      "properties": {
        "namespace_prefix": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "state": {
      "type": "string",
      "minLength": 1
    }
  }
}

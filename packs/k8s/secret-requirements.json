[
  {
    "key": "k8s_bearer_token",
    "description": "Bearer token for API auth (omit when using in-cluster or kubeconfig).",
    "required": false,
    "scope": {
      "env": "dev",
      "tenant": "example"
    },
    "format": "text"
  },
  {
    "key": "kubeconfig_b64",
    "description": "Base64-encoded kubeconfig content for out-of-cluster auth.",
    "required": false,
    "scope": {
      "env": "dev",
      "tenant": "example"
    },
    "format": "bytes"
  },
  {
    "key": "audit_sink_credentials",
    "description": "Credentials or token for the configured audit sink (Splunk/GCP/Azure/http).",
    "required": true,
    "scope": {
      "env": "dev",
      "tenant": "example"
    },
    "format": "text"
  }
]

{
  "provider_id": "greentic.secrets.gcp-sm",
  "config": {
    "required": [
      "tenant_id",
      "environment",
      "project_id",
      "auth_mode",
      "namespace_prefix",
      "timeouts",
      "retry_policy",
      "redaction_policy"
    ],
    "optional": [
      "location",
      "labels",
      "audit"
    ],
    "constraints": {
      "enum": {
        "environment": [
          "dev",
          "stage",
          "prod"
        ],
        "auth_mode": [
          "workload_identity",
          "service_account_json"
        ]
      }
    }
  },
  "secrets": {
    "required": [],
    "optional": [
      "gcp_service_account_json",
      "audit_sink_credentials"
    ],
    "constraints": {
      "required_when": {
        "audit_sink_credentials": {
          "config_path": "audit.sink_type",
          "values": [
            "splunk",
            "azure",
            "gcp",
            "http"
          ]
        }
      }
    }
  },
  "capabilities": {
    "supports_read": true,
    "supports_write": true,
    "supports_delete": true
  },
  "setup_needs": {
    "public_base_url": false,
    "oauth": false,
    "subscriptions": false
  }
}
